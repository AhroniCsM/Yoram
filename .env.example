# Environment variables read by server.js.
# In production these are set as Fly secrets (NOT committed):
#   fly secrets set KEY=value KEY2=value2
# For local dev you can copy this file to .env and `export $(cat .env | xargs)`.

# --- Email notifications (Resend) ---
# Sign up free: https://resend.com  (100/day, 3000/month)
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=leads@yourdomain.com   # a verified domain in Resend
LEAD_NOTIFY_EMAIL=ahroniss@gmail.com     # where lead emails are sent

# --- WhatsApp notifications (CallMeBot, free) ---
# 1) On the receiving phone, save +34 644 51 95 00 as a contact (CallMeBot)
# 2) Send it the WhatsApp message: "I allow callmebot to send me messages"
# 3) Paste the apikey it replies with below.
# Phone = country code + number, no + or dashes (e.g. 972505508499)
CALLMEBOT_PHONE=972505508499
CALLMEBOT_APIKEY=your_callmebot_apikey_here

# --- Admin page — Basic Auth ---
# The admin page that lists all contact submissions stays LOCKED (503)
# until BOTH user + password are set.
ADMIN_USER=yoram
ADMIN_PASSWORD=use_a_long_random_password
# Secret URL path for the admin page (defaults to "admin" if unset).
# Set this to a private word so the page isn't at the obvious /admin.
ADMIN_PATH=admin
